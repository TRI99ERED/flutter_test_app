rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Email verification codes - users can only access their own
    match /email_verification_codes/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Mail collection - only backend can write, no client access needed
    match /mail/{mailId} {
      allow read, write: if false;
    }
    
    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
